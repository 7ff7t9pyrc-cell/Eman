<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>For EMAN ❤️</title>

<link rel="preconnect" href="https://fonts.googleapis.com">

<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

html{
scroll-behavior:smooth;
}

body{

background:#050816;

overflow:hidden;

height:100vh;

display:flex;

justify-content:center;

align-items:center;

color:white;

position:relative;

}

/* Aurora */

#aurora{

position:fixed;

inset:0;

background:

radial-gradient(circle at top,#ff4fa020 0%,transparent 40%),

radial-gradient(circle at bottom,#7b61ff25 0%,transparent 45%),

linear-gradient(180deg,#050816,#090b16);

z-index:-4;

}

/* Stars */

#stars{

position:fixed;

inset:0;

overflow:hidden;

z-index:-3;

}

.star{

position:absolute;

width:2px;

height:2px;

background:white;

border-radius:50%;

opacity:.8;

animation:blink 2s infinite;

}

@keyframes blink{

50%{

opacity:.2;

transform:scale(.5);

}

}

/* Hearts */

#hearts{

position:fixed;

inset:0;

pointer-events:none;

z-index:-2;

overflow:hidden;

}

.heart{

position:absolute;

bottom:-50px;

color:#ff5ca8;

opacity:.25;

animation:float linear forwards;

}

@keyframes float{

0%{

transform:translateY(0) scale(.5);

}

100%{

transform:translateY(-120vh) scale(1.4);

opacity:0;

}

}

/* Loading */

#loading{

position:fixed;

inset:0;

display:flex;

justify-content:center;

align-items:center;

flex-direction:column;

background:#050816;

z-index:9999;

transition:1s;

}

.loading-heart{

font-size:70px;

animation:pulse 1.2s infinite;

margin-bottom:20px;

}

#loading h2{

font-size:30px;

margin-bottom:10px;

}

#loading p{

opacity:.7;

}

@keyframes pulse{

0%{

transform:scale(1);

}

50%{

transform:scale(1.15);

}

100%{

transform:scale(1);

}

}

/* Card */

.card{

display:none;

width:92%;

max-width:430px;

padding:40px;

border-radius:30px;

text-align:center;

background:rgba(255,255,255,.08);

backdrop-filter:blur(18px);

border:1px solid rgba(255,255,255,.12);

box-shadow:

0 0 60px rgba(255,0,120,.15);

animation:fade .8s;

}

@keyframes fade{

from{

opacity:0;

transform:translateY(40px);

}

to{

opacity:1;

transform:translateY(0);

}

}

.tag{

display:block;

letter-spacing:4px;

font-size:13px;

opacity:.75;

margin-bottom:15px;

text-transform:uppercase;

}

.card h1{

font-size:48px;

margin-bottom:20px;

background:linear-gradient(90deg,#ff74c8,#ffffff);

-webkit-background-clip:text;

-webkit-text-fill-color:transparent;

}

#message{

min-height:120px;

font-size:18px;

line-height:1.9;

margin-bottom:35px;

}

.buttons{

display:flex;

flex-direction:column;

gap:12px;

}

button{

border:none;

padding:16px;

border-radius:40px;

cursor:pointer;

font-size:17px;

font-weight:600;

background:linear-gradient(135deg,#ff4fa0,#ff758c);

color:white;

transition:.3s;

}

button:hover{

transform:scale(1.03);

}

button:active{

transform:scale(.96);

}

#next{

display:none;

}

/* Secret */

#secret{

display:none;

text-align:center;

animation:fade .8s;

}

#secret h2{

font-size:70px;

margin-bottom:20px;

animation:pulse 1.5s infinite;

}

#secret h1{

font-size:48px;

margin-bottom:20px;

background:linear-gradient(90deg,#ff7dc5,#ffffff);

-webkit-background-clip:text;

-webkit-text-fill-color:transparent;

}

#secret p{

font-size:20px;

opacity:.9;

margin-bottom:35px;

}

/* Mobile */

@media(max-width:600px){

.card{

padding:30px;

}

.card h1{

font-size:38px;

}

#message{

font-size:16px;

}

#secret h1{

font-size:34px;

}

button{

font-size:16px;

}

}

</style>

</head>

<body>

<!-- Loading Screen -->

<div id="loading">

<div class="loading-heart">❤️</div>

<h2>Loading My Heart...</h2>

<p>Made especially for EMAN</p>

</div>

<!-- Animated Background -->

<div id="aurora"></div>

<div id="stars"></div>

<div id="hearts"></div>

<!-- Main Card -->

<div class="card" id="card">

<span class="tag">

Made Especially For

</span>

<h1>

EMAN❤️

</h1>

<p id="message">

Every word you'll read here comes from my heart...

</p>

<div class="buttons">

<button id="start">

Open My Heart ❤️

</button>

<button id="next">

Next ❤️

</button>

</div>

</div>

<!-- Secret Message -->

<div id="secret">

<h2>

❤️

</h2>

<h1>

I Love You EMAN

</h1>

<p>

Forever isn't long enough with you.

</p>

<button id="restart">

Replay ❤️

</button>

</div>

<script>

const loading = document.getElementById("loading");
const card = document.getElementById("card");
const secret = document.getElementById("secret");

const start = document.getElementById("start");
const next = document.getElementById("next");
const restart = document.getElementById("restart");

const message = document.getElementById("message");

/* ==========================
   Loading
========================== */

window.onload = () => {

setTimeout(() => {

loading.style.opacity = "0";

setTimeout(() => {

loading.style.display = "none";

card.style.display = "block";

},800);

},2200);

};

/* ==========================
   Messages
========================== */

const messages = [

"Hi EMAN 🌸",

"Sometimes life gives us someone who changes everything...",

"You became my favorite hello and my hardest goodbye.",

"I smile a little more because of you ❤️",

"If I had another lifetime... I'd still choose you.",

"Thank you for being part of my life.",

"I hope this little surprise made you smile ❤️"

];

let index = 0;

start.onclick = () => {

message.innerHTML = messages[0];

start.style.display = "none";

next.style.display = "block";

index = 1;

};

next.onclick = () => {

if(index < messages.length){

message.style.opacity = 0;

setTimeout(()=>{

message.innerHTML = messages[index];

message.style.opacity = 1;

},250);

index++;

}else{

card.style.display = "none";

secret.style.display = "block";

}

};

restart.onclick = () =>{

location.reload();

};

/* ==========================
   Stars
========================== */

const stars = document.getElementById("stars");

for(let i=0;i<120;i++){

const star = document.createElement("div");

star.className="star";

star.style.left=Math.random()*100+"vw";

star.style.top=Math.random()*100+"vh";

star.style.animationDelay=Math.random()*2+"s";

stars.appendChild(star);

}

/* ==========================
   Floating Hearts
========================== */

const hearts=document.getElementById("hearts");

setInterval(()=>{

const heart=document.createElement("div");

heart.className="heart";

heart.innerHTML="❤️";

heart.style.left=Math.random()*100+"vw";

heart.style.fontSize=(16+Math.random()*18)+"px";

heart.style.animationDuration=(6+Math.random()*5)+"s";

hearts.appendChild(heart);

setTimeout(()=>{

heart.remove();

},11000);

},450);

/* ==========================
   Optional Music
========================== */

/*

لو هتضيف أغنية

ضيف داخل الـ body قبل script

<audio id="music" loop>

<source src="music.mp3" type="audio/mpeg">

</audio>

ثم احذف التعليق من السطور التالية

const music=document.getElementById("music");

start.onclick=()=>{

music.play();

...

}

*/

</script>

</body>

</html>
